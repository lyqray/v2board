            {
                "domain_suffix": [
                    ".googleapis.cn",
                    ".googleapis.com",
                    ".xn--ngstr-lra8j.com",
                    ".xn--ngstr-cn-8za9o.com"
                ],
                "rule_set": [
                    "geosite-google",
                    "geosite-youtube",
                    "geosite-tiktok",
                    "geosite-telegram"
                ],
                "action": "route",
                "server": "fakeip"
            },
            {
                "query_type": [
                    "A",
                    "AAAA"
                ],
                "server": "fakeip"
            }
        ],
        "final": "remote-dns"
    },
