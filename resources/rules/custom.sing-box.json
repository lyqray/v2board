            },
            {
                "type": "udp",
                "tag": "remote-dns",
                "server": "1.1.1.1"
            },
            {
                "type": "fakeip",
                "tag": "fakeip",
                "inet4_range": "198.18.0.0/15",
                "inet6_range": "fc00::/18"
            }
        ],
        "rules": [
            {
                "inbound": [
                    "direct-in"
                ],
                "source_ip_is_private": true,
